msgid "TxtCow SMS:"
msgstr "TxtCow SMS:"

msgid "WooCommerce is required to use this plugin."
msgstr "이 플러그인을 사용하려면 WooCommerce가 필요합니다."

msgid "TxtCow SMS Settings"
msgstr "TxtCow SMS 설정"

msgid "TxtCow SMS"
msgstr "TxtCow SMS"

msgid "Phone number is missing."
msgstr "전화번호가 없습니다."

msgid "Cannot normalize phone number."
msgstr "전화번호를 표준화할 수 없습니다."

msgid "TxtCow SMS not sent: opt-out number (%s)"
msgstr "TxtCow SMS 미전송: 옵트아웃 번호 (%s)"

msgid "API key is not configured."
msgstr "API 키가 설정되지 않았습니다."

msgid "TxtCow SMS not sent: central blocklist (%s)"
msgstr "TxtCow SMS 미전송: 중앙 블록리스트 (%s)"

msgid "TxtCow SMS queued: %s"
msgstr "TxtCow SMS 큐잉됨: %s"

msgid "TxtCow SMS failed: %s"
msgstr "TxtCow SMS 실패: %s"

msgid "[Admin Alert] New order (#%s) received. Amount: %s"
msgstr "[관리자 알림] 새 주문(#%s)이 접수되었습니다. 금액: %s"

msgid "Settings saved!"
msgstr "설정이 저장되었습니다!"

msgid "Test SMS sent!"
msgstr "테스트 SMS가 전송되었습니다!"

msgid "SMS send failed: %s"
msgstr "SMS 전송 실패: %s"

msgid "Please fill in all fields."
msgstr "모든 필드를 입력해주세요."

msgid "Basic Settings"
msgstr "기본 설정"

msgid "Message Settings"
msgstr "메시지 설정"

msgid "Message Rules"
msgstr "메시지 규칙"

msgid "Delay Settings"
msgstr "지연 설정"

msgid "Connection Status"
msgstr "연결 상태"

msgid "Delivery Logs"
msgstr "발송 로그"

msgid "Test SMS"
msgstr "테스트 SMS"

msgid "API Key"
msgstr "API 키"

msgid "Enter the API key issued in Integrations from TxtCow Dashboard."
msgstr "TxtCow Dashboard의 Integrations에서 발급받은 API 키를 입력하세요."

msgid "Admin Notifications"
msgstr "관리자 알림"

msgid "Send admin SMS for new orders"
msgstr "관리자에게 새 주문 알림"

msgid "Receive text messages on admin phone when new orders arrive"
msgstr "새 주문이 들어오면 관리자 휴대폰으로 문자 받기"

msgid "Enter your phone number to stay on top of orders."
msgstr "주문을 놓치지 않도록 사장님/운영자 휴대폰 번호를 입력하세요."

msgid "Admin Phone Number"
msgstr "관리자 휴대폰 번호"

msgid "Enable Customer Notifications"
msgstr "고객 알림 활성화"

msgid "Order Received (Processing)"
msgstr "주문 접수 (Processing)"

msgid "Send SMS to customer when order is received"
msgstr "주문이 접수되면 고객에게 SMS 전송"

msgid "Order Completed"
msgstr "주문 완료 (Completed)"

msgid "Send SMS to customer when order is completed"
msgstr "주문이 완료되면 고객에게 SMS 전송"

msgid "Order Cancelled"
msgstr "주문 취소 (Cancelled)"

msgid "Send SMS to customer when order is cancelled"
msgstr "주문이 취소되면 고객에게 SMS 전송"

msgid "SMS Send Restrictions (Opt-out Numbers)"
msgstr "발신 제한(옵트아웃) 번호"

msgid "Enter one phone number per line. Numbers listed here will not receive SMS in any status."
msgstr "한 줄에 한 번호씩 입력하세요. 여기에 있는 번호는 어떤 상태에서도 발송되지 않습니다."

msgid "Open TxtCow Dashboard"
msgstr "TxtCow Dashboard 열기"

msgid "✓ Automatic Opt-out Enabled!"
msgstr "✓ 자동 옵트아웃 활성화됨!"

msgid "When customers reply with \"STOP\", \"Unsubscribe\", etc., TxtCow system automatically detects it and adds to the central blocklist."
msgstr "고객이 \"STOP\", \"수신거부\" 등의 키워드로 회신하면 TxtCow 시스템이 자동으로 감지하여 중앙 블록리스트에 추가합니다."

msgid "Supported Keywords: STOP, UNSUBSCRIBE, CANCEL, END, QUIT, OPT-OUT, REMOVE"
msgstr "지원 키워드: STOP, UNSUBSCRIBE, CANCEL, END, QUIT, OPT-OUT, REMOVE, 수신거부, 거부, 중지"

msgid "Manual Opt-out Numbers"
msgstr "수동 옵트아웃 번호 목록"

msgid "Numbers you enter here will be automatically synced to TxtCow's central blocklist."
msgstr "여기에 직접 입력한 번호는 TxtCow 중앙 블록리스트에 자동으로 동기화됩니다."

msgid "Save Settings"
msgstr "설정 저장"

msgid "{order_number} - Order number"
msgstr "{order_number} - 주문 번호"

msgid "{customer_name} - Customer name"
msgstr "{customer_name} - 고객 이름"

msgid "{total} - Order total"
msgstr "{total} - 총 결제 금액"

msgid "{items_list} - Product list (e.g., Apple x 1, Pear x 2)"
msgstr "{items_list} - 상품 목록 (예: 사과 x 1, 배 x 2)"

msgid "{billing_address} - Billing/shipping address"
msgstr "{billing_address} - 청구/배송 주소"

msgid "{tracking_number} - Tracking number"
msgstr "{tracking_number} - 송장 번호"

msgid "{tracking_link} - Shipping tracking link"
msgstr "{tracking_link} - 배송 추적 링크"

msgid "TxtCow SMS pending review in app: %s"
msgstr "TxtCow SMS 앱에서 검토 대기 중: %s"

msgid "API key settings"
msgstr "API 키 설정"

msgid "to start sending SMS."
msgstr "SMS 발송을 시작하세요."

msgid "Test SMS is pending review in TxtCow app. Please open the app to approve and send it."
msgstr "테스트 SMS가 TxtCow 앱에서 검토 대기 중입니다. 앱을 열어 승인하고 발송하세요."

msgid "John Doe"
msgstr "홍길동"

msgid "Sample product x 1"
msgstr "샘플 상품 x 1"

msgid "No order found. Rendering with sample values."
msgstr "주문이 없어 샘플 값으로 렌더링했습니다."

msgid "Preview order: #%s / %s"
msgstr "미리보기 기준 주문: #%s / %s"

msgid "Rule %d: Template cannot be empty."
msgstr "규칙 %d: 템플릿은 비워둘 수 없습니다."

msgid "Rule %d: Unsupported event type."
msgstr "규칙 %d: 지원하지 않는 이벤트 타입입니다."

msgid "Rule %d: Minimum order amount cannot be greater than maximum order amount."
msgstr "규칙 %d: 최소 주문 금액이 최대 주문 금액보다 클 수 없습니다."

msgid "Rule %d: Customer name regex pattern is invalid."
msgstr "규칙 %d: 고객 이름 regex 패턴이 올바르지 않습니다."

msgid "Message Rule Validation Results"
msgstr "메시지 규칙 검증 결과"

msgid "In New Zealand, send messages only for purposes allowed by the Unsolicited Electronic Messages Act 2007, such as quote requests, existing transaction progress or confirmation, warranty, recall, safety, membership or account notices, and government or court notices. Comply with local spam and telecommunications rules in every country, do not send to numbers that opted out, and accept responsibility for all messages you send."
msgstr "뉴질랜드에서는 Unsolicited Electronic Messages Act 2007이 허용하는 목적(견적 요청, 기존 거래 진행/확인, 보증, 리콜, 안전, 회원/계정 안내, 정부/법원 안내 등)으로만 발송하세요. 모든 국가의 현지 스팸/통신 규제를 준수하고, 수신자가 거부한 번호에는 발송하지 마세요. 모든 발송 책임은 사용자에게 있습니다."

msgid "Available Variables:"
msgstr "사용 가능한 변수:"

msgid "Order Received Message"
msgstr "주문 접수 메시지"

msgid "Order Completed Message"
msgstr "주문 완료 메시지"

msgid "Order Cancelled Message"
msgstr "주문 취소 메시지"

msgid "Message Preview"
msgstr "메시지 미리보기"

msgid "Preview Order"
msgstr "미리보기 주문"

msgid "Leave empty to use the most recent order. If no order exists, sample values are used."
msgstr "비워두면 가장 최근 주문을 사용합니다. 주문이 없으면 샘플 값으로 렌더링합니다."

msgid "Order Received"
msgstr "주문 접수"

msgid "Save Messages"
msgstr "메시지 저장"

msgid "Conditional Message Rules"
msgstr "조건부 메시지 규칙"

msgid "Rules are evaluated from top to bottom. The first matching rule is applied; if none match, the default message template is used."
msgstr "위에서 아래 순서대로 평가합니다. 먼저 일치한 규칙이 적용되며, 일치하지 않으면 기본 메시지 템플릿을 사용합니다."

msgid "Rule order is the priority. Place specific customer group rules above general rules."
msgstr "규칙 순서가 곧 우선순위입니다. 특정 고객군 규칙을 위에 두고, 일반 규칙을 아래에 두세요."

msgid "Priority"
msgstr "우선순위"

msgid "Enabled"
msgstr "사용"

msgid "Rule Name"
msgstr "규칙 이름"

msgid "Event"
msgstr "이벤트"

msgid "Country"
msgstr "국가"

