msgstr "고객명 Regex"

msgid "Message Template"
msgstr "메시지 템플릿"

msgid "Actions"
msgstr "조작"

msgid "e.g., VIP order"
msgstr "예: VIP 주문"

msgid "e.g., Apple"
msgstr "예: 사과"

msgid "e.g., ^Kim"
msgstr "예: ^김"

